{
  "name": "taskpilot",
  "version": "0.1.0",
  "description": "A CLI task board tool — a local, file-based Trello from the terminal",
  "bin": {
    "taskpilot": "bin/taskpilot"
  },
  "files": [
    "bin/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "bundle": "node esbuild.config.mjs",
    "build:full": "npm run build && npm run bundle",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "prepare": "npm run build:full"
  },
  "keywords": [
    "cli",
    "task",
    "board",
    "productivity"
  ],
  "author": "TaskPilot Contributors",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.24.2",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}